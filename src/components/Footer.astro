---
import { site } from "../config/site";

const { username, social } = site;
const githubUrl = social.github
  ? `https://github.com/${social.github}`
  : undefined;
---

<footer class="footer">
  <p>
    Built with Astro and <span class="love" aria-hidden="true">❤</span> by
    {
      githubUrl ? (
        <a href={githubUrl} target="_blank" rel="noopener noreferrer">
          {username}
        </a>
      ) : (
        username
      )
    }
  </p>
</footer>

<style>
  .footer {
    padding: 1.25rem;
    background: #0b131c;
    color: rgba(255, 255, 255, 0.8);
    text-align: center;
  }

  .footer a {
    color: #ffffff;
  }

  .love {
    color: #ff6b6b;
  }
</style>
